# ──────────────────────────────────────────────────────────────
# App Paciente AUTON Health — backend read-only
# Conecta ao banco via API do Supabase com a SERVICE_ROLE (server-side),
# que ignora RLS. A segurança por-paciente é feita no código (auth GSD).
# ──────────────────────────────────────────────────────────────

# Supabase (projeto mtjgjvwpjwwmnebdholz)
SUPABASE_URL=https://mtjgjvwpjwwmnebdholz.supabase.co

# ⚠️ SECRETA — Settings → API → service_role. NUNCA expor no front.
SUPABASE_SERVICE_ROLE_KEY=

SERVER_PORT=3333
NODE_ENV=development

# (Opcional) fallback de verificação de JWT por HS256 (Settings → API → JWT Secret)
# SUPABASE_JWT_SECRET=

# (Opcional) restringe CORS à origem do app do paciente
# CORS_ORIGIN=http://localhost:3000

# ⚠️ DEV ONLY — bypass de auth (identidade via header x-dev-usuario-auth). NUNCA em prod.
# DEV_AUTH_BYPASS=true
